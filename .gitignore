# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
*.key
*.p12
*.pfx

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — NEVER commit credentials
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Proprietary image assets — exist locally, must never be pushed
# (copyrighted photos & logos belonging to Brit English Academy)
/public/imgs/
/app/icon.png
# scratch / debug screenshots in the repo root
cta-fix.png

# Local QA / bug-hunt scratch scripts and screenshots (root-level, prefixed with _)
/_*.mjs
/_*.png
/_*.webp
/_*.jpg
/_*.avif
/_*.bin
/_*.txt

# Local image drafts — kept for reference, not committed
/public/free-imgs/Oldest ones/
/public/free-imgs/phoenix-v1.0_*.jpg

# Supabase
/supabase/.temp/
supabase/.branches/
supabase/.env

# Logs
*.log
logs/

.vercel
